<script>
// ===================================================================
// STATE
// ===================================================================
const STORAGE_KEY = 'pk-freelancer-guide';
let state = loadState();

function defaultState() {
  return {
    steps: [false, false, false, false, false, false],
    calculator: { monthly: 1500, method: 'payoneer', pseb: 'unknown', filer: 'unsure' },
    repatriation: { total: '', bank: '', esfca: '' },
    calculated: false
  };
}

function loadState() {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    if (raw) {
      const parsed = JSON.parse(raw);
      // merge with defaults to handle missing keys
      return { ...defaultState(), ...parsed };
    }
  } catch(e) {}
  return defaultState();
}

function saveState() {
  try { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); } catch(e) {}
}

// ===================================================================
// INIT — Restore saved state
// ===================================================================
document.addEventListener('DOMContentLoaded', function() {
  // Restore calculator inputs
  document.getElementById('monthlyIncome').value = state.calculator.monthly;
  document.getElementById('incomeSlider').value = state.calculator.monthly;
  document.getElementById('paymentMethod').value = state.calculator.method;
  document.getElementById('psebStatus').value = state.calculator.pseb;
  document.getElementById('filerStatus').value = state.calculator.filer;
  updateAnnualDisplay();

  // Restore checkboxes
  for (let i = 0; i < 6; i++) {
    document.getElementById('check' + (i + 1)).checked = state.steps[i];
  }

  // Restore repatriation
  if (state.repatriation.total) document.getElementById('repTotal').value = state.repatriation.total;
  if (state.repatriation.bank) document.getElementById('repBank').value = state.repatriation.bank;
  if (state.repatriation.esfca) document.getElementById('repESFCA').value = state.repatriation.esfca;
  calculateRepatriation();

  // If previously calculated, show results
  if (state.calculated) {
    calculateSavings(true);
  }

  updateProgressBar();
});

// ===================================================================
// SLIDER <-> INPUT SYNC
// ===================================================================
function syncSlider() {
  const val = parseInt(document.getElementById('monthlyIncome').value) || 100;
  document.getElementById('incomeSlider').value = val;
  updateAnnualDisplay();
}

function syncInput() {
  const val = parseInt(document.getElementById('incomeSlider').value) || 100;
  document.getElementById('monthlyIncome').value = val;
  updateAnnualDisplay();
}

function updateAnnualDisplay() {
  const m = parseInt(document.getElementById('monthlyIncome').value) || 0;
  document.getElementById('annualDisplay').textContent = '$' + (m * 12).toLocaleString() + '/yr';
}

// ===================================================================
// SAVINGS CALCULATOR
// ===================================================================
let calcResults = null; // store for use by progress bar

function calculateSavings(silent) {
  const monthly = parseInt(document.getElementById('monthlyIncome').value) || 1500;
  const method = document.getElementById('paymentMethod').value;
  const pseb = document.getElementById('psebStatus').value;
  const filer = document.getElementById('filerStatus').value;
  const annual = monthly * 12;

  // Save to state
  state.calculator = { monthly, method, pseb, filer };
  state.calculated = true;
  saveState();

  // --- Platform Fee Calculation ---
  let currentPlatformFee = 0;
  let platformLabel = '';

  if (method === 'payoneer') {
    const receivingFee = annual * 0.01;   // 1%
    const fxMarkup = annual * 0.025;      // 2.5%
    currentPlatformFee = receivingFee + fxMarkup; // 3.5%
    platformLabel = 'Payoneer fees (1% receiving + 2.5% FX)';
  } else if (method === 'wise') {
    const transferFee = annual * 0.01;    // 1%
    const fxMarkup = annual * 0.005;      // 0.5%
    currentPlatformFee = transferFee + fxMarkup; // 1.5%
    platformLabel = 'Wise fees (1% transfer + 0.5% FX)';
  } else if (method === 'wire') {
    currentPlatformFee = 24 * 25;         // $600/yr
    platformLabel = 'Wire transfer fees (~$25 × 24/yr)';
  } else {
    // Other/mixed — assume Payoneer-like
    currentPlatformFee = annual * 0.03;
    platformLabel = 'Estimated platform fees (~3%)';
  }

  const cenoaFee = annual * 0.0099;       // 0.99%
  const platformSavings = Math.max(0, currentPlatformFee - cenoaFee);

  // --- Tax Calculation ---
  let currentTaxRate, currentTaxLabel;
  if (pseb === 'yes') {
    currentTaxRate = 0.0025; // already registered
    currentTaxLabel = '0.25% (PSEB registered)';
  } else {
    currentTaxRate = 0.01;   // 1%
    currentTaxLabel = '1% (no PSEB registration)';
  }
  const optimizedTaxRate = 0.0025;
  const currentTax = annual * currentTaxRate;
  const optimizedTax = annual * optimizedTaxRate;
  const taxSavings = Math.max(0, currentTax - optimizedTax);

  // --- Non-filer Costs ---
  let nonFilerLow = 0, nonFilerHigh = 0, nonFilerLabel = '';
  const isFiler = filer === 'yes';
  if (!isFiler) {
    nonFilerLow = 100;
    nonFilerHigh = 525;
    nonFilerLabel = '~$' + nonFilerLow + '–$' + nonFilerHigh + '/yr est.';
  } else {
    nonFilerLabel = '$0';
  }
  const nonFilerMid = (nonFilerLow + nonFilerHigh) / 2;

  // --- 80% rule ---
  const is80Unknown = true; // always show as benefit

  // --- Totals ---
  const totalCurrentLow = currentPlatformFee + currentTax + nonFilerLow;
  const totalCurrentHigh = currentPlatformFee + currentTax + nonFilerHigh;
  const totalOptimized = cenoaFee + optimizedTax;
  const totalSaveLow = totalCurrentLow - totalOptimized;
  const totalSaveHigh = totalCurrentHigh - totalOptimized;
  const totalSaveMid = (totalSaveLow + totalSaveHigh) / 2;

  // Store results for progress bar
  calcResults = {
    platformSavings,
    taxSavings,
    nonFilerMid,
    nonFilerLow,
    nonFilerHigh,
    totalSaveLow,
    totalSaveHigh,
    totalSaveMid,
    annual,
    isFiler,
    psebRegistered: pseb === 'yes'
  };

  // --- Fill Results Panel ---
  const fmt = v => '$' + Math.round(Math.abs(v)).toLocaleString();

  document.getElementById('resultAnnualIncome').textContent = '$' + annual.toLocaleString() + '/year';

  // Platform
  document.getElementById('r-currentPlatform').textContent = '-' + fmt(currentPlatformFee) + '/yr';
  document.getElementById('r-optimizedPlatform').textContent = '-' + fmt(cenoaFee) + '/yr (Cenoa 0.99%)';
  document.getElementById('r-savePlatform').textContent = fmt(platformSavings);

  // Tax
  document.getElementById('r-currentTax').textContent = currentTaxLabel + ' (-' + fmt(currentTax) + ')';
  document.getElementById('r-optimizedTax').textContent = '0.25% (-' + fmt(optimizedTax) + ')';
  document.getElementById('r-saveTax').textContent = taxSavings > 0 ? fmt(taxSavings) : '$0';

  // Non-filer
  if (!isFiler) {
    document.getElementById('r-currentNonFiler').textContent = nonFilerLabel;
    document.getElementById('r-optimizedNonFiler').textContent = '$0';
    document.getElementById('r-saveNonFiler').textContent = nonFilerLabel;
  } else {
    document.getElementById('r-currentNonFiler').textContent = '$0 (you file)';
    document.getElementById('r-optimizedNonFiler').textContent = '$0';
    document.getElementById('r-saveNonFiler').textContent = '$0';
  }

  // 80%
  document.getElementById('r-current80').textContent = '⚠️ Not tracking — risk of 45% tax';

  // Totals
  if (nonFilerHigh > 0) {
    document.getElementById('r-totalCurrent').textContent = '-' + fmt(totalCurrentLow) + ' to -' + fmt(totalCurrentHigh) + '/yr';
    document.getElementById('r-totalSave').textContent = '💰 ' + fmt(totalSaveLow) + '–' + fmt(totalSaveHigh) + '/yr';
  } else {
    document.getElementById('r-totalCurrent').textContent = '-' + fmt(totalCurrentLow) + '/yr';
    document.getElementById('r-totalSave').textContent = '💰 ' + fmt(totalSaveLow) + '/yr';
  }
  document.getElementById('r-totalOptimized').textContent = '-' + fmt(totalOptimized) + '/yr';

  // Big savings
  if (nonFilerHigh > 0) {
    document.getElementById('bigSavings').textContent = fmt(totalSaveLow) + '–' + fmt(totalSaveHigh);
    const monthlyLow = Math.round(totalSaveLow / 12);
    const monthlyHigh = Math.round(totalSaveHigh / 12);
    document.getElementById('monthlySavingsText').textContent =
      "That's $" + monthlyLow.toLocaleString() + '–$' + monthlyHigh.toLocaleString() + ' extra in your pocket every month';
  } else {
    document.getElementById('bigSavings').textContent = fmt(totalSaveLow);
    document.getElementById('monthlySavingsText').textContent =
      "That's $" + Math.round(totalSaveLow / 12).toLocaleString() + ' extra in your pocket every month';
  }

  // Detailed breakdown
  let breakdown = '';
  breakdown += '<div class="bg-red-50 rounded-lg p-4 border border-red-200">';
  breakdown += '<p class="font-bold text-red-700 mb-2">🔴 WHAT YOU\'RE LOSING NOW:</p>';
  breakdown += '<ul class="space-y-1 text-red-700">';
  breakdown += '<li>├── ' + platformLabel + ': <strong>-' + fmt(currentPlatformFee) + '/yr</strong></li>';
  breakdown += '<li>├── Tax at ' + currentTaxLabel + ': <strong>-' + fmt(currentTax) + '/yr</strong></li>';
  if (!isFiler) {
    breakdown += '<li>├── Non-filer penalties on daily life: <strong>-$' + nonFilerLow + ' to $' + nonFilerHigh + '/yr (est.)</strong></li>';
  }
  breakdown += '<li>├── 80% rule compliance: <strong>⚠️ Not tracking — risk of 45% tax</strong></li>';
  breakdown += '<li class="font-bold pt-1">│   Total losses: ~' + fmt(totalCurrentLow);
  if (nonFilerHigh > 0) breakdown += ' to ' + fmt(totalCurrentHigh);
  breakdown += '/yr</li>';
  breakdown += '</ul></div>';

  breakdown += '<div class="bg-green-50 rounded-lg p-4 border border-green-200 mt-3">';
  breakdown += '<p class="font-bold text-green-700 mb-2">🟢 AFTER COMPLETING THE JOURNEY:</p>';
  breakdown += '<ul class="space-y-1 text-green-700">';
  breakdown += '<li>├── Cenoa fees (0.99%): <strong>-' + fmt(cenoaFee) + '/yr</strong></li>';
  breakdown += '<li>├── Tax at 0.25% (PSEB registered): <strong>-' + fmt(optimizedTax) + '/yr</strong></li>';
  breakdown += '<li>├── Filer status (reduced rates everywhere): <strong>$0 extra</strong></li>';
  breakdown += '<li>├── 80% rule tracking: <strong>✅ Protected</strong></li>';
  breakdown += '<li class="font-bold pt-1">│   Total costs: ~' + fmt(totalOptimized) + '/yr</li>';
  breakdown += '</ul></div>';

  document.getElementById('detailedBreakdown').innerHTML = breakdown;

  // Show results panel
  const panel = document.getElementById('resultsPanel');
  panel.classList.remove('hidden');
  panel.classList.add('visible');

  // Update step-specific savings displays
  updateStepSavings();
  updateProgressBar();

  // Scroll to results (unless silent restore)
  if (!silent) {
    panel.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }
}

function updateStepSavings() {
  if (!calcResults) return;
  const { nonFilerLow, nonFilerHigh, platformSavings, taxSavings, annual } = calcResults;
  const fmt = v => '$' + Math.round(v).toLocaleString();

  if (nonFilerLow > 0) {
    document.getElementById('step1-savings').textContent = '$' + nonFilerLow + '–$' + nonFilerHigh + '/yr saved';
  } else {
    document.getElementById('step1-savings').textContent = 'Already a filer ✅';
  }

  document.getElementById('step3-savings').textContent = fmt(platformSavings) + '/yr saved';

  if (taxSavings > 0) {
    document.getElementById('step4-savings').textContent = fmt(taxSavings) + '/yr saved';
  } else {
    document.getElementById('step4-savings').textContent = 'Already at 0.25% ✅';
  }
}

// ===================================================================
// ACCORDION
// ===================================================================
function toggleAccordion(num) {
  const body = document.getElementById('body' + num);
  const chevron = document.getElementById('chevron' + num);
  const isOpen = body.classList.contains('open');

  if (isOpen) {
    body.classList.remove('open');
    chevron.classList.remove('rotate');
  } else {
    body.classList.add('open');
    chevron.classList.add('rotate');
  }
}

// ===================================================================
// STEP CHECKBOXES
// ===================================================================
function toggleStep(num) {
  const checked = document.getElementById('check' + num).checked;
  state.steps[num - 1] = checked;
  saveState();
  updateProgressBar();
}

// ===================================================================
// PROGRESS BAR
// ===================================================================
function updateProgressBar() {
  const completed = state.steps.filter(Boolean).length;
  const pct = (completed / 6) * 100;

  document.getElementById('progressFill').style.width = pct + '%';
  document.getElementById('progressLabel').textContent = 'Step ' + completed + ' of 6';

  // Calculate savings per step
  let totalPossibleSavings = 0;
  let unlockedSavings = 0;

  if (calcResults) {
    // Step savings allocation:
    // Step 1: non-filer savings
    // Step 2: 0 (foundation)
    // Step 3: platform savings
    // Step 4: tax savings
    // Step 5: 0 (insurance)
    // Step 6: 0 (protection)
    const stepValues = [
      calcResults.nonFilerMid,     // Step 1
      0,                            // Step 2
      calcResults.platformSavings,  // Step 3
      calcResults.taxSavings,       // Step 4
      0,                            // Step 5
      0                             // Step 6
    ];

    totalPossibleSavings = stepValues.reduce((a, b) => a + b, 0);
    unlockedSavings = stepValues.reduce((a, b, i) => a + (state.steps[i] ? b : 0), 0);
  }

  const fmt = v => '$' + Math.round(v).toLocaleString();
  document.getElementById('progressSavings').textContent = 'Savings unlocked: ' + fmt(unlockedSavings) + '/yr';
  document.getElementById('unlockedText').textContent = '✅ ' + fmt(unlockedSavings) + '/yr unlocked';
  document.getElementById('remainingText').textContent = '🔓 ' + fmt(Math.max(0, totalPossibleSavings - unlockedSavings)) + '/yr remaining';

  // Show/hide completion section
  const completionSection = document.getElementById('completionSection');
  if (completed === 6) {
    completionSection.style.display = 'block';
    if (calcResults) {
      const { totalSaveLow, totalSaveHigh } = calcResults;
      const savingsText = totalSaveHigh > totalSaveLow
        ? '$' + Math.round(totalSaveLow).toLocaleString() + '–$' + Math.round(totalSaveHigh).toLocaleString()
        : '$' + Math.round(totalSaveLow).toLocaleString();
      document.getElementById('completionSavingsText').textContent =
        "You've optimized your freelancing finances and can save ~" + savingsText + "/year!";
    }
  } else {
    completionSection.style.display = 'none';
  }
}

// ===================================================================
// 80% REPATRIATION TRACKER
// ===================================================================
function calculateRepatriation() {
  const total = parseFloat(document.getElementById('repTotal').value) || 0;
  const bank = parseFloat(document.getElementById('repBank').value) || 0;
  const esfca = parseFloat(document.getElementById('repESFCA').value) || 0;

  // Save to state
  state.repatriation = {
    total: document.getElementById('repTotal').value,
    bank: document.getElementById('repBank').value,
    esfca: document.getElementById('repESFCA').value
  };
  saveState();

  const repatriated = bank + esfca;
  const pct = total > 0 ? (repatriated / total) * 100 : 0;

  document.getElementById('repRepatriated').textContent = '$' + Math.round(repatriated).toLocaleString();

  const pctEl = document.getElementById('repPercentage');
  pctEl.textContent = total > 0 ? pct.toFixed(1) + '%' : '0%';

  const gauge = document.getElementById('repGauge');
  const msgEl = document.getElementById('repMessage');

  // Cap gauge at 100%
  gauge.style.width = Math.min(pct, 100) + '%';

  if (total === 0) {
    gauge.style.backgroundColor = '#9ca3af';
    pctEl.style.color = '#6b7280';
    msgEl.className = 'text-sm font-semibold p-3 rounded-lg bg-gray-100 text-gray-500 text-center';
    msgEl.textContent = 'Enter your amounts above to track your repatriation status.';
  } else if (pct >= 85) {
    gauge.style.backgroundColor = '#22c55e';
    pctEl.style.color = '#16a34a';
    msgEl.className = 'text-sm font-semibold p-3 rounded-lg bg-green-100 text-green-700 text-center';
    msgEl.textContent = '✅ Great! You\'re well above the 80% threshold. Keep it up!';
  } else if (pct >= 80) {
    gauge.style.backgroundColor = '#eab308';
    pctEl.style.color = '#ca8a04';
    msgEl.className = 'text-sm font-semibold p-3 rounded-lg bg-yellow-100 text-yellow-700 text-center';
    const needed = Math.ceil(total * 0.85 - repatriated);
    msgEl.textContent = '⚠️ You\'re just at the threshold. Repatriate $' + needed.toLocaleString() + ' more to have a comfortable margin above 85%.';
  } else {
    gauge.style.backgroundColor = '#ef4444';
    pctEl.style.color = '#dc2626';
    msgEl.className = 'text-sm font-semibold p-3 rounded-lg bg-red-100 text-red-700 text-center';
    const needed = Math.ceil(total * 0.80 - repatriated);
    msgEl.textContent = '🚨 Below 80%! You need to repatriate $' + Math.max(0, needed).toLocaleString() + ' more before June 30 to stay compliant.';
  }
}

// ===================================================================
// SCROLL TO JOURNEY
// ===================================================================
function scrollToJourney() {
  document.getElementById('journeySection').scrollIntoView({ behavior: 'smooth', block: 'start' });
}
</script>
</body>
</html>
