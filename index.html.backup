<!-- ===== HEADER ===== -->
<header class="cenoa-header">
  <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">
    <a href="https://cenoa-nextjs-pearl.vercel.app/" class="flex items-center gap-2">
      <span class="text-2xl font-extrabold text-cenoa-dark tracking-tight">Cenoa</span>
    </a>
    <a href="https://onelink.ext.cenoa.com/K9pU/cenoacomstart" class="cta-btn">Open Free Account</a>
  </div>
</header>

<!-- ===== HERO ===== -->
<section class="hero-gradient text-white py-12 md:py-16 px-4">
  <div class="max-w-3xl mx-auto text-center">
    <p class="text-cenoa-mint font-semibold text-sm uppercase tracking-widest mb-2">🇵🇰 Pakistan Freelancer Guide</p>
    <h1 class="text-3xl md:text-5xl font-extrabold mb-4 leading-tight">How Much Money Are You<br>Leaving on the Table?</h1>
    <p class="text-white/80 text-lg md:text-xl max-w-2xl mx-auto">Most Pakistani freelancers lose <strong class="text-cenoa-mint">$500–$2,000 every year</strong> to hidden fees, wrong tax rates, and missed registrations. Let's find your number.</p>
  </div>
</section>

<!-- ===== SECTION 1: SAVINGS CALCULATOR ===== -->
<main class="max-w-5xl mx-auto px-4 py-10">

  <!-- Calculator Inputs -->
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 md:p-8 mb-6" id="calculatorSection">
    <h2 class="font-bold text-xl text-cenoa-dark mb-2">💰 Your Savings Calculator</h2>
    <p class="text-gray-500 text-sm mb-6">Answer 4 questions and see your personalized savings report.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Monthly income -->
      <div class="md:col-span-2">
        <label class="calc-label" for="monthlyIncome">Monthly Income (USD)</label>
        <div class="flex items-center gap-4">
          <div class="relative flex-1">
            <span class="input-prefix font-bold">$</span>
            <input type="number" id="monthlyIncome" class="calc-input pl-8" min="100" max="20000" step="100" value="1500" oninput="syncSlider()" />
          </div>
          <span class="text-sm text-gray-400 font-medium whitespace-nowrap" id="annualDisplay">$18,000/yr</span>
        </div>
        <input type="range" id="incomeSlider" min="100" max="20000" step="100" value="1500" class="mt-3" oninput="syncInput()" />
        <div class="flex justify-between text-xs text-gray-400 mt-1">
          <span>$100</span>
          <span>$5,000</span>
          <span>$10,000</span>
          <span>$20,000</span>
        </div>
      </div>

      <!-- Payment method -->
      <div>
        <label class="calc-label" for="paymentMethod">How do you receive payments?</label>
        <select id="paymentMethod" class="calc-select">
          <option value="payoneer" selected>Payoneer</option>
          <option value="wise">Wise</option>
          <option value="wire">Direct bank wire</option>
          <option value="other">Other / Mixed</option>
        </select>
      </div>

      <!-- PSEB status -->
      <div>
        <label class="calc-label" for="psebStatus">Registered with PSEB (Tech Destination)?</label>
        <select id="psebStatus" class="calc-select">
          <option value="no">No</option>
          <option value="yes">Yes</option>
          <option value="unknown" selected>What's that?</option>
        </select>
      </div>

      <!-- Filer status -->
      <div class="md:col-span-2">
        <label class="calc-label" for="filerStatus">Do you file income tax returns?</label>
        <select id="filerStatus" class="calc-select md:w-1/2">
          <option value="no">No</option>
          <option value="yes">Yes</option>
          <option value="unsure" selected>Not sure</option>
        </select>
      </div>
    </div>

    <!-- Tax warning -->
    <div class="warning-box mt-6">
      ⚠️ <strong>Tax credit status under Section 65F may vary</strong> — verify for current fiscal year before filing. The rates shown here use the standard withholding rates (1% without PSEB, 0.25% with PSEB).
    </div>

    <!-- Calculate Button -->
    <button onclick="calculateSavings()" class="calc-btn mt-6">
      Calculate My Savings →
    </button>
  </div>

  <!-- Results Panel (hidden initially) -->
  <div id="resultsPanel" class="hidden">
    <!-- Results heading -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 md:p-8 mb-6">
      <h3 class="font-bold text-xl text-cenoa-dark mb-1">📊 Your Annual Savings Report</h3>
      <p class="text-gray-500 text-sm mb-4">Annual income: <strong id="resultAnnualIncome">$18,000/year</strong></p>

      <!-- Comparison Table -->
      <div class="table-scroll">
        <table class="content-table w-full">
          <thead>
            <tr>
              <th class="rounded-tl-lg"></th>
              <th>Your Current Situation</th>
              <th>After Completing the Journey</th>
              <th class="rounded-tr-lg">You Save</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="font-semibold text-gray-700">Platform fees</td>
              <td class="text-red-600 font-semibold" id="r-currentPlatform">—</td>
              <td class="text-green-600 font-semibold" id="r-optimizedPlatform">—</td>
              <td class="text-green-700 font-bold" id="r-savePlatform">—</td>
            </tr>
            <tr>
              <td class="font-semibold text-gray-700">Tax rate</td>
              <td class="text-red-600 font-semibold" id="r-currentTax">—</td>
              <td class="text-green-600 font-semibold" id="r-optimizedTax">—</td>
              <td class="text-green-700 font-bold" id="r-saveTax">—</td>
            </tr>
            <tr>
              <td class="font-semibold text-gray-700">Non-filer costs</td>
              <td class="text-red-600 font-semibold" id="r-currentNonFiler">—</td>
              <td class="text-green-600 font-semibold" id="r-optimizedNonFiler">$0</td>
              <td class="text-green-700 font-bold" id="r-saveNonFiler">—</td>
            </tr>
            <tr>
              <td class="font-semibold text-gray-700">80% rule risk</td>
              <td class="text-amber-600 font-semibold" id="r-current80">⚠️ Unknown</td>
              <td class="text-green-600 font-semibold">✅ Protected</td>
              <td class="text-green-700 font-bold">Peace of mind</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="font-bold text-cenoa-dark text-base">TOTAL</td>
              <td class="text-red-600 font-bold text-base" id="r-totalCurrent">—</td>
              <td class="text-green-600 font-bold text-base" id="r-totalOptimized">—</td>
              <td class="text-green-700 font-extrabold text-base" id="r-totalSave">—</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Big Savings Banner -->
    <div class="savings-pulse bg-gradient-to-r from-green-500 to-emerald-600 rounded-2xl p-6 md:p-8 text-white text-center mb-6 shadow-lg">
      <p class="text-green-100 font-semibold uppercase text-sm tracking-widest mb-2">Your estimated annual savings</p>
      <div class="text-5xl md:text-6xl font-extrabold mb-2" id="bigSavings">$0</div>
      <p class="text-green-100 text-lg" id="monthlySavingsText">That's $0 extra in your pocket every month</p>
      <div class="mt-4">
        <a href="#journeySection" class="inline-block bg-white text-green-700 font-bold px-8 py-3 rounded-xl hover:bg-green-50 transition-colors text-lg" onclick="scrollToJourney()">
          Start the Journey ↓
        </a>
      </div>
    </div>

    <!-- Detailed breakdown -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 mb-6">
      <h4 class="font-bold text-cenoa-dark mb-3">📋 Detailed Breakdown</h4>
      <div class="space-y-3 text-sm" id="detailedBreakdown">
        <!-- Filled by JS -->
      </div>
    </div>
  </div>

  <!-- ===== SECTION 2: THE JOURNEY — 6 STEPS ===== -->
  <div id="journeySection" class="mb-8">
    <div class="text-center mb-8">
      <h2 class="text-2xl md:text-3xl font-extrabold text-cenoa-dark mb-2">Your 6-Step Savings Journey</h2>
      <p class="text-gray-500 max-w-2xl mx-auto">Complete each step to unlock your full savings potential. Check off steps as you go — your progress is saved automatically.</p>
    </div>

    <!-- ===== STICKY PROGRESS BAR ===== -->
    <div id="progressBar" class="bg-white border-b border-gray-200 shadow-sm py-3 px-4 rounded-xl mb-6">
      <div class="max-w-5xl mx-auto">
        <div class="flex items-center justify-between mb-2">
          <span class="text-sm font-bold text-cenoa-dark" id="progressLabel">Step 0 of 6</span>
          <span class="text-xs text-gray-500" id="progressSavings">Savings unlocked: $0/yr</span>
        </div>
        <div class="bg-gray-200 rounded-full h-3 overflow-hidden">
          <div id="progressFill" class="progress-fill h-full rounded-full bg-gradient-to-r from-cenoa-blue to-cenoa-mint" style="width: 0%"></div>
        </div>
        <div class="flex justify-between mt-1">
          <span class="text-xs text-green-600 font-semibold" id="unlockedText">✅ $0/yr unlocked</span>
          <span class="text-xs text-gray-400" id="remainingText">🔓 $0/yr remaining</span>
        </div>
      </div>
    </div>

    <!-- ===== STEP 1: Become a Tax Filer ===== -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 mb-4 overflow-hidden" id="step1-card">
      <div class="step-header flex items-center gap-4 p-5 cursor-pointer select-none transition-colors" onclick="toggleAccordion(1)">
        <input type="checkbox" class="step-check" id="check1" onclick="event.stopPropagation(); toggleStep(1)" />
        <div class="flex-1">
          <div class="flex items-center gap-2 flex-wrap">
            <span class="bg-cenoa-blue text-white text-xs font-bold px-2.5 py-1 rounded-full">Step 1</span>
            <span class="font-bold text-cenoa-dark text-lg">Become a Tax Filer</span>
          </div>
          <p class="text-gray-500 text-sm mt-1">Unlocks: Reduced rates on everything in life · <span class="text-green-600 font-semibold" id="step1-savings">$100–525/yr saved</span></p>
        </div>
        <svg class="accordion-chevron w-6 h-6 text-gray-400 flex-shrink-0" id="chevron1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
      </div>
      <div class="accordion-body" id="body1">
        <div class="px-5 pb-6 pt-2 border-t border-gray-100">
          <!-- Why -->
          <h4 class="font-bold text-cenoa-dark mb-2 text-base">Why This Matters</h4>
          <p class="text-gray-700 text-sm mb-3">Being a non-filer in Pakistan doesn't just mean you don't file taxes. It means you <strong>pay MORE</strong> on practically everything:</p>
          <ul class="text-sm text-gray-700 space-y-1.5 mb-4 ml-4">
            <li>• <strong>Property purchase tax:</strong> 10% instead of 3%</li>
            <li>• <strong>Vehicle registration:</strong> 2–3 times higher</li>
            <li>• <strong>Cash withdrawal tax:</strong> double (0.6% vs 0.3%)</li>
            <li>• <strong>Bank savings tax:</strong> 35% instead of 15%</li>
            <li>• <strong>Airport departure:</strong> PKR 30,000 instead of 15,000</li>
            <li>• Your <strong>SIM card can be blocked</strong></li>
            <li>• You <strong>can't buy property</strong> above PKR 5 million</li>
            <li>• You <strong>can't buy vehicles</strong> above PKR 7 million</li>
          </ul>

          <!-- How -->
          <h4 class="font-bold text-cenoa-dark mb-2 text-base">How to Do It (Step-by-Step)</h4>
          <div class="space-y-4 text-sm text-gray-700">
            <div>
              <p class="font-semibold text-gray-800 mb-1">1. Get your NTN (National Tax Number)</p>
              <ul class="ml-4 space-y-1">
                <li>• Go to FBR IRIS portal: <a href="https://iris.fbr.gov.pk" target="_blank" rel="noopener" class="text-cenoa-blue underline hover:text-cenoa-dark">iris.fbr.gov.pk</a></li>
                <li>• Your NTN = your CNIC number (national ID number)</li>
                <li>• Register with your CNIC + mobile number</li>
                <li>• Complete registration form with income details</li>
              </ul>
            </div>
            <div>
              <p class="font-semibold text-gray-800 mb-1">2. File your income tax return</p>
              <ul class="ml-4 space-y-1">
                <li>• Log into IRIS portal</li>
                <li>• Select "Income Tax Return" for current tax year</li>
                <li>• Declare all income (export + local)</li>
                <li>• File Wealth Statement (required even if income is low)</li>
                <li>• Deadline: September 30 each year (subject to extensions)</li>
              </ul>
            </div>
            <div>
              <p class="font-semibold text-gray-800 mb-1">3. Verify your Active Taxpayer status</p>
              <ul class="ml-4 space-y-1">
                <li>• Check ATL: <a href="https://e.fbr.gov.pk/esbn/Loging.aspx" target="_blank" rel="noopener" class="text-cenoa-blue underline hover:text-cenoa-dark">e.fbr.gov.pk/esbn/Loging.aspx</a></li>
                <li>• Enter your CNIC → should show "Active"</li>
                <li>• ATL is updated on October 1 each year</li>
              </ul>
            </div>
          </div>

          <div class="flex gap-4 mt-4 text-xs text-gray-500">
            <span>⏱ Time: ~1–2 hours online</span>
            <span>💰 Cost: Free</span>
          </div>
        </div>
      </div>
    </div>

    <!-- ===== STEP 2: Open a Freelancer Bank Account ===== -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 mb-4 overflow-hidden" id="step2-card">
      <div class="step-header flex items-center gap-4 p-5 cursor-pointer select-none transition-colors" onclick="toggleAccordion(2)">
        <input type="checkbox" class="step-check" id="check2" onclick="event.stopPropagation(); toggleStep(2)" />
        <div class="flex-1">
          <div class="flex items-center gap-2 flex-wrap">
            <span class="bg-cenoa-blue text-white text-xs font-bold px-2.5 py-1 rounded-full">Step 2</span>
            <span class="font-bold text-cenoa-dark text-lg">Open a Freelancer Bank Account</span>
          </div>
          <p class="text-gray-500 text-sm mt-1">Unlocks: USD retention + correct bank certificates · <span class="text-green-600 font-semibold">Foundation for everything</span></p>
        </div>
        <svg class="accordion-chevron w-6 h-6 text-gray-400 flex-shrink-0" id="chevron2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
      </div>
      <div class="accordion-body" id="body2">
        <div class="px-5 pb-6 pt-2 border-t border-gray-100">
          <h4 class="font-bold text-cenoa-dark mb-2 text-base">Why You Need This</h4>
          <p class="text-gray-700 text-sm mb-3">Most Pakistani freelancers use their regular bank account (or JazzCash/NayaPay). A <strong>"Freelancer Account"</strong> is a special account type that:</p>
          <ul class="text-sm text-gray-700 space-y-1.5 mb-4 ml-4">
            <li>• Comes with a linked <strong>USD account (ESFCA)</strong> where you can keep dollars</li>
            <li>• Automatically processes foreign remittances correctly</li>
            <li>• Issues <strong>PRCs</strong> (bank certificates) that you need for tax benefits</li>
            <li>• Lets you pay for tools and subscriptions directly in USD</li>
          </ul>

          <div class="info-box mb-4">
            <strong>💡 What is ESFCA?</strong><br>
            Exporters' Special Foreign Currency Account. The government lets you keep up to <strong>$5,000/month or 50% of your earnings</strong> (whichever is higher) in USD inside Pakistan. You get a debit card that works for international online payments. No more blocked Canva or ChatGPT subscriptions.
          </div>

          <h4 class="font-bold text-cenoa-dark mb-2 text-base">How to Open One</h4>
          <div class="space-y-4 text-sm text-gray-700">
            <div>
              <p class="font-semibold text-gray-800 mb-1">1. Choose a bank — best options for freelancers:</p>
              <ul class="ml-4 space-y-1">
                <li>• <strong>Meezan Bank</strong> — Payoneer partnership, auto e-PRC, Islamic banking</li>
                <li>• <strong>UBL</strong> — Online account opening, good freelancer support</li>
                <li>• <strong>Allied Bank</strong> — Online/app opening, straightforward process</li>
                <li>• <strong>Faysal Bank</strong> — Competitive FX rates</li>
              </ul>
            </div>
            <div>
              <p class="font-semibold text-gray-800 mb-1">2. Open the account</p>
              <ul class="ml-4 space-y-1">
                <li>• <strong>Online:</strong> UBL, Allied Bank allow digital opening via app</li>
                <li>• <strong>Branch:</strong> Meezan requires branch visit but has best Payoneer integration</li>
                <li>• You'll get <strong>TWO accounts:</strong> PKR account + linked ESFCA (USD/EUR/GBP)</li>
              </ul>
            </div>
            <div>
              <p class="font-semibold text-gray-800 mb-1">3. Documents needed</p>
              <ul class="ml-4 space-y-1">
                <li>• CNIC</li>
                <li>• Proof of freelance income (Payoneer/Upwork statements)</li>
                <li>• PSEB certificate (helpful but usually not required just to open)</li>
              </ul>
            </div>
            <div>
              <p class="font-semibold text-gray-800 mb-1">4. Set your USD retention percentage</p>
              <ul class="ml-4 space-y-1">
                <li>• Tell the bank how much of each remittance to keep in USD</li>
                <li>• Rest is auto-converted to PKR at bank's rate</li>
                <li>• You can change this by visiting the branch</li>
              </ul>
            </div>
          </div>

          <div class="flex gap-4 mt-4 text-xs text-gray-500">
            <span>⏱ Time: 1–3 days</span>
            <span>💰 Cost: Free (most banks)</span>
          </div>
        </div>
