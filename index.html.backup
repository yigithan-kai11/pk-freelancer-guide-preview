  <link rel="stylesheet" href="../shared.css" />
  <style>
    /* Smooth accordion transitions */
    .accordion-body {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.4s ease, padding 0.3s ease;
    }
    .accordion-body.open {
      max-height: 12000px;
      transition: max-height 0.8s ease-in, padding 0.3s ease;
    }

    /* Chevron rotation */
    .accordion-chevron {
      transition: transform 0.3s ease;
    }
    .accordion-chevron.rotate {
      transform: rotate(180deg);
    }

    /* Progress bar animation */
    .progress-fill {
      transition: width 0.6s ease;
    }

    /* Savings pulse */
    @keyframes pulse-savings {
      0%, 100% { transform: scale(1); }
      50%      { transform: scale(1.02); }
    }
    .savings-pulse { animation: pulse-savings 2s ease-in-out infinite; }

    /* Gauge */
    .gauge-fill {
      transition: width 0.5s ease, background-color 0.3s ease;
    }

    /* Step card hover */
    .step-header:hover {
      background: #f0f4ff;
    }

    /* Custom checkbox styling */
    .step-check {
      width: 22px;
      height: 22px;
      accent-color: #0A3DBF;
      cursor: pointer;
      flex-shrink: 0;
    }

    /* Slider styling */
    input[type="range"] {
      -webkit-appearance: none;
      width: 100%;
      height: 8px;
      border-radius: 4px;
      background: #e5e7eb;
      outline: none;
    }
    input[type="range"]::-webkit-slider-thumb {
      -webkit-appearance: none;
      width: 24px;
      height: 24px;
      border-radius: 50%;
      background: #0A3DBF;
      cursor: pointer;
      border: 3px solid #fff;
      box-shadow: 0 2px 6px rgba(0,0,0,0.2);
    }
    input[type="range"]::-moz-range-thumb {
      width: 24px;
      height: 24px;
      border-radius: 50%;
      background: #0A3DBF;
      cursor: pointer;
      border: 3px solid #fff;
      box-shadow: 0 2px 6px rgba(0,0,0,0.2);
    }

    /* Data table inside accordions */
    .content-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
    .content-table th { background: #061E6E; color: #fff; padding: 0.5rem 0.75rem; text-align: left; font-weight: 600; font-size: 0.8rem; }
    .content-table td { padding: 0.5rem 0.75rem; border-bottom: 1px solid #e5e7eb; }
    .content-table tr:nth-child(even) td { background: #f9fafb; }

    /* Warning box */
    .warning-box {
      background: #fef3c7;
      border: 1px solid #fbbf24;
      border-radius: 8px;
      padding: 0.75rem 1rem;
      font-size: 0.85rem;
      color: #92400e;
    }

    /* Info box */
    .info-box {
      background: #eff6ff;
      border: 1px solid #93c5fd;
      border-radius: 8px;
      padding: 0.75rem 1rem;
      font-size: 0.85rem;
      color: #1e40af;
    }

    /* Sticky progress bar */
    #progressBar {
      position: sticky;
      top: 52px;
      z-index: 90;
      transition: box-shadow 0.3s ease;
    }

    /* Results panel animation */
    #resultsPanel {
      transition: opacity 0.4s ease, transform 0.4s ease;
    }
    #resultsPanel.hidden {
      opacity: 0;
      transform: translateY(20px);
      pointer-events: none;
      max-height: 0;
      overflow: hidden;
    }
    #resultsPanel.visible {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
      max-height: none;
    }

    /* Scrollbar for tables on mobile */
    .table-scroll { overflow-x: auto; -webkit-overflow-scrolling: touch; }

    /* Print hide */
    @media print {
      #progressBar, .cenoa-header, .footer-cta { display: none !important; }
    }
  </style>
</head>
