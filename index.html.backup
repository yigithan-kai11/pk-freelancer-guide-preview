  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: { extend: { colors: {
        'cenoa-blue': '#0A3DBF',
        'cenoa-mint': '#88DCC4',
        'cenoa-dark': '#061E6E',
      }}}
